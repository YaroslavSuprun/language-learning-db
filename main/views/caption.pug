html
    head
        title #{caption.text}
        link(rel="stylesheet" href="/styles.css")
    body
        include ./partials/header

        h1 Caption: #{caption.text} (#{caption.language})
        h2 Translations:
        ul
            each translation in translations
                li #{translation.text} (#{translation.language}) - Source: #{translation.source}
        h2 Appears in:
        ul
            each video in videos
                li
                    a(href=`/videos/${video.video_id}`) #{video.title}
                    span  | #{formatTime(video.start_time)} - #{formatTime(video.end_time)}